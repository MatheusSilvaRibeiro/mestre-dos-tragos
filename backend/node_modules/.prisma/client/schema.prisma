generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  ADMIN
  ATENDENTE
  COZINHA
}

enum StatusPedido {
  PENDENTE
  EM_PREPARO
  PRONTO
  ENTREGUE
  CANCELADO
}

enum TipoProduto {
  LANCHE
  BATATA_FRITA
  PORCAO_MISTA
}

enum Tamanho {
  P
  M
  G
}

// ─────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────

model Usuario {
  id       String   @id @default(uuid())
  nome     String
  usuario  String   @unique
  senha    String
  role     Role     @default(ATENDENTE)
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now())

  pedidos Pedido[]

  @@map("usuarios")
}

model Categoria {
  id       String   @id @default(uuid())
  nome     String   @unique
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now())

  produtos Produto[]

  @@map("categorias")
}

model Produto {
  id           String      @id @default(uuid())
  nome         String
  descricao    String?
  emoji        String? // ← novo campo
  preco        Decimal     @db.Decimal(10, 2)
  tipo         TipoProduto @default(LANCHE)
  disponivel   Boolean     @default(true)
  ativo        Boolean     @default(true)
  categoriaId  String
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt

  categoria         Categoria          @relation(fields: [categoriaId], references: [id])
  tamanhos          ProdutoTamanho[]
  adicionaisProduto ProdutoAdicional[]
  itensPedido       ItemPedido[]

  @@map("produtos")
}

model ProdutoTamanho {
  id        String  @id @default(uuid())
  produtoId String
  tamanho   Tamanho
  preco     Decimal @db.Decimal(10, 2)

  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([produtoId, tamanho])
  @@map("produto_tamanhos")
}

model Adicional {
  id    String  @id @default(uuid())
  nome  String
  preco Decimal @db.Decimal(10, 2)
  ativo Boolean @default(true)

  precoPorTamanho AdicionalTamanho[]
  produtos        ProdutoAdicional[]
  itens           ItemPedidoAdicional[]

  @@map("adicionais")
}

model AdicionalTamanho {
  id          String  @id @default(uuid())
  adicionalId String
  tamanho     Tamanho
  preco       Decimal @db.Decimal(10, 2)

  adicional Adicional @relation(fields: [adicionalId], references: [id], onDelete: Cascade)

  @@unique([adicionalId, tamanho])
  @@map("adicional_tamanhos")
}

model ProdutoAdicional {
  id          String @id @default(uuid())
  produtoId   String
  adicionalId String

  produto   Produto   @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  adicional Adicional @relation(fields: [adicionalId], references: [id], onDelete: Cascade)

  @@unique([produtoId, adicionalId])
  @@map("produto_adicionais")
}

model Pedido {
  id           String       @id @default(uuid())
  numeroPedido Int          @unique @default(autoincrement())
  usuarioId    String? // ← nullable
  nomeCliente  String?
  status       StatusPedido @default(PENDENTE)
  observacoes  String?
  valorTotal   Decimal      @db.Decimal(10, 2)
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt
  finalizadoEm DateTime?

  usuario Usuario?     @relation(fields: [usuarioId], references: [id], onDelete: SetNull) // ← SetNull
  itens   ItemPedido[]

  @@map("pedidos")
}

model ItemPedido {
  id          String   @id @default(uuid())
  pedidoId    String
  produtoId   String
  quantidade  Int
  precoUnit   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  tamanho     Tamanho?
  observacoes String?
  criadoEm    DateTime @default(now())

  pedido     Pedido                @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto    Produto               @relation(fields: [produtoId], references: [id])
  adicionais ItemPedidoAdicional[]
  sabores    ItemPedidoSabor[]

  @@map("itens_pedido")
}

model ItemPedidoAdicional {
  id           String  @id @default(uuid())
  itemPedidoId String
  adicionalId  String
  preco        Decimal @db.Decimal(10, 2)

  itemPedido ItemPedido @relation(fields: [itemPedidoId], references: [id], onDelete: Cascade)
  adicional  Adicional  @relation(fields: [adicionalId], references: [id])

  @@map("itens_pedido_adicionais")
}

model ItemPedidoSabor {
  id           String @id @default(uuid())
  itemPedidoId String
  nome         String

  itemPedido ItemPedido @relation(fields: [itemPedidoId], references: [id], onDelete: Cascade)

  @@map("itens_pedido_sabores")
}
